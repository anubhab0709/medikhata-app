PORT=5001
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/medikhata
JWT_SECRET=<generate-with: openssl rand -hex 64>
JWT_EXPIRES_IN=7d
# Comma-separated. No trailing slashes.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://medikhata-app.vercel.app
NODE_ENV=development

# App / branding (used in emails)
APP_NAME=KhataApp
APP_URL=https://medikhata-app.vercel.app
SUPPORT_EMAIL=heyanubhab@gmail.com
SUPPORT_CONTACT_EMAIL=khata.app2026@gmail.com
SUPPORT_PHONE=8617569139

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
#
# IMPORTANT for inbox delivery (avoid spam):
# 1. Add + verify your domain in Resend (SPF + DKIM).
# 2. Add a DMARC TXT record: v=DMARC1; p=none; rua=mailto:you@yourdomain.com
# 3. Do NOT use onboarding@resend.dev in production — Gmail often marks it as spam.
# 4. From address must use your verified domain, e.g.:
RESEND_FROM=KhataApp <otp@mail.itsanubhab.com>
# Optional reply address (should also be on a mailbox you monitor)
RESEND_REPLY_TO=khata.app2026@gmail.com

# OTP / security
OTP_EXPIRY_MINUTES=10
BCRYPT_ROUNDS=12
# For Vercel frontend + Render backend use:
# COOKIE_SAMESITE=none
# NODE_ENV=production
# Set true ONLY for local console OTP fallback when Resend is unset
# EMAIL_DEV_FALLBACK=true
# ALLOW_DEV_OTP=true
